{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-command/docs/contracts/production-readiness-audit-v0.1.schema.json",
  "title": "AO Command Production Readiness Audit v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "readiness_percent",
    "passed_gates",
    "total_gates",
    "failed_checks",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": "ao.command.production-readiness-audit.v0.1"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "readiness_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "passed_gates": {
      "type": "integer",
      "minimum": 0
    },
    "total_gates": {
      "type": "integer",
      "minimum": 1
    },
    "failed_checks": {
      "type": "integer",
      "minimum": 0
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "status", "summary"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]+$"
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "readiness_percent": {
            "const": 100
          },
          "failed_checks": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "readiness_percent": {
            "maximum": 99
          },
          "failed_checks": {
            "minimum": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
