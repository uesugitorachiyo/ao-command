{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-command/blob/main/docs/contracts/operator-status-source-v0.1.schema.json",
  "title": "AO operator status source v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "reported_status",
    "objective",
    "correlation_id",
    "active_repository",
    "workgraph_id",
    "active_node_id",
    "nodes",
    "approval",
    "verification",
    "worker",
    "started_at",
    "progress_percent",
    "release",
    "exact_blocker",
    "exact_next_action",
    "evidence",
    "final_report",
    "safety"
  ],
  "properties": {
    "schema": {
      "const": "ao.operator.status-source.v0.1"
    },
    "reported_status": {
      "enum": [
        "running",
        "waiting_approval",
        "ready",
        "blocked",
        "completed"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "active_repository": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "workgraph_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "active_node_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "nodes": {
      "$ref": "#/$defs/nodeCounts"
    },
    "approval": {
      "$ref": "#/$defs/approval"
    },
    "verification": {
      "$ref": "#/$defs/verification"
    },
    "worker": {
      "$ref": "#/$defs/worker"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "progress_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "release": {
      "$ref": "#/$defs/release"
    },
    "exact_blocker": {
      "type": "string",
      "maxLength": 2048
    },
    "exact_next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "evidence": {
      "$ref": "#/$defs/evidenceList"
    },
    "final_report": {
      "$ref": "#/$defs/finalReport"
    },
    "safety": {
      "$ref": "#/$defs/safety"
    }
  },
  "$defs": {
    "nodeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "completed",
        "running",
        "ready",
        "blocked",
        "remaining"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 1
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "running": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "ready": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "remaining": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "action_digest",
        "exact_instruction"
      ],
      "properties": {
        "state": {
          "enum": [
            "none",
            "waiting"
          ]
        },
        "action_digest": {
          "type": "string",
          "maxLength": 71
        },
        "exact_instruction": {
          "type": "string",
          "maxLength": 2048
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "evidence"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "running",
            "failed",
            "blocked",
            "not_run"
          ]
        },
        "evidence": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tests",
        "ci"
      ],
      "properties": {
        "tests": {
          "$ref": "#/$defs/check"
        },
        "ci": {
          "$ref": "#/$defs/check"
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "heartbeat_at",
        "fresh_for_seconds"
      ],
      "properties": {
        "state": {
          "enum": [
            "running",
            "idle",
            "stopped"
          ]
        },
        "heartbeat_at": {
          "type": "string",
          "maxLength": 64
        },
        "fresh_for_seconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "mission_version",
        "command_version",
        "publicly_available",
        "publication_attempted"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_attempted",
            "candidate_only",
            "no_release"
          ]
        },
        "mission_version": {
          "type": "string",
          "maxLength": 128
        },
        "command_version": {
          "type": "string",
          "maxLength": 128
        },
        "publicly_available": {
          "const": false
        },
        "publication_attempted": {
          "const": false
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "location",
        "sha256"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "evidenceList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "finalReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "location",
        "sha256"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "location": {
          "type": "string",
          "maxLength": 2048
        },
        "sha256": {
          "type": "string",
          "maxLength": 71
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_mode",
        "safe_to_execute",
        "executes_work",
        "approves_work",
        "mutates_repositories",
        "calls_providers",
        "releases_or_deploys"
      ],
      "properties": {
        "operator_mode": {
          "const": "read_only"
        },
        "safe_to_execute": {
          "const": false
        },
        "executes_work": {
          "const": false
        },
        "approves_work": {
          "const": false
        },
        "mutates_repositories": {
          "const": false
        },
        "calls_providers": {
          "const": false
        },
        "releases_or_deploys": {
          "const": false
        }
      }
    }
  }
}
