{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-command/docs/contracts/install-verify-audit-v0.1.schema.json",
  "title": "AO Command Install Verify Audit v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "generated_at_utc",
    "head_commit",
    "installed_binary",
    "mutates_repositories",
    "mutates_releases",
    "uploads_artifacts",
    "network_required",
    "checks",
    "artifacts",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "ao.command.install-verify-audit.v0.1"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "head_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40,64}$"
    },
    "installed_binary": {
      "type": "string",
      "minLength": 1
    },
    "mutates_repositories": {
      "const": false
    },
    "mutates_releases": {
      "const": false
    },
    "uploads_artifacts": {
      "const": false
    },
    "network_required": {
      "const": false
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "status", "summary"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]+$"
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "description", "required"],
        "properties": {
          "action_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "next_actions": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "next_actions": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
